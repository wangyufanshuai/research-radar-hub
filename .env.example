# Research Radar Hub environment template
# Copy this file to .env and fill only the values you need.

# Optional: GitHub Personal Access Token for higher public API rate limits.
# No special scopes are needed for public repository search.
GITHUB_PAT=

# Optional: enables LLM summaries. Without it, rule-based summaries are used.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional: SMTP settings for daily report email delivery.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# Optional for Docker/Next.js: backend URL used by frontend API rewrites.
NEXT_PUBLIC_API_PROXY_BASE=http://backend:8000
